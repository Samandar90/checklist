generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  admins       Admin[]
  adminBranches AdminBranch[]
  rooms        Room[]
  reports      MonthlyReport[]
  expenses     Expense[]
  cashShifts   CashShift[]
}

model Admin {
  id        String   @id @default(cuid())
  fullName  String
  phone     String
  branchId  String // основной (домашний) филиал
  createdAt DateTime @default(now())

  branch       Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  branches     AdminBranch[] // все филиалы, где работает админ (включая основной)
  reports      MonthlyReport[]
  expenses     Expense[]
  cashShifts   CashShift[]
  user         User?
}

// Многие-ко-многим: админ может работать в нескольких филиалах.
model AdminBranch {
  adminId  String
  branchId String

  admin  Admin  @relation(fields: [adminId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([adminId, branchId])
  @@index([branchId])
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("ADMIN")
  adminId      String?  @unique
  createdAt    DateTime @default(now())

  admin Admin? @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model Room {
  id         String   @id @default(cuid())
  roomNumber String
  type       String? // тип номера: DBL, TWIN, Lux …
  branchId   String
  createdAt  DateTime @default(now())

  branch  Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  reports MonthlyReport[]
}

model BookingSource {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  reports MonthlyReport[]
}

model MonthlyReport {
  id        String    @id @default(cuid())
  date      DateTime // дата заезда (check-in)
  checkOut  DateTime? // дата выезда (check-out); null = одна ночь
  guestName String? // имя гостя
  branchId  String
  adminId   String
  roomId    String
  sourceId  String
  price         Float
  currency      String
  paymentMethod String   @default("Наличные")
  paymentStatus String   @default("Оплачено")
  status        String   @default("RESERVED") // RESERVED | CHECKED_IN | CHECKED_OUT | CANCELLED | NO_SHOW
  paidAmount    Float?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime? @updatedAt

  // Restrict: нельзя удалить админа/номер/источник, пока за ними числятся брони —
  // финансовая история не должна пропадать каскадом.
  branch Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  admin  Admin         @relation(fields: [adminId], references: [id], onDelete: Restrict)
  room   Room          @relation(fields: [roomId], references: [id], onDelete: Restrict)
  source BookingSource @relation(fields: [sourceId], references: [id], onDelete: Restrict)

  @@index([branchId, date])
  @@index([roomId, date])
  @@index([adminId])
  @@index([status])
  @@index([paymentStatus])
}

model Expense {
  id        String    @id @default(cuid())
  date      DateTime
  branchId  String
  adminId   String?
  category  String
  amount    Float
  currency  String    @default("UZS")
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  admin  Admin? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([branchId, date])
  @@index([adminId])
}

model CashShift {
  id            String    @id @default(cuid())
  branchId      String
  adminId       String
  openedAt      DateTime  @default(now())
  closedAt      DateTime?
  openingAmount Float
  closingAmount Float? // фактически посчитано админом при закрытии
  expectedAmount Float? // расчёт системы на момент закрытия (нал. приход - расход)
  currency      String    @default("UZS")
  status        String    @default("OPEN") // OPEN | CLOSED
  notes         String?
  createdAt     DateTime  @default(now())

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  admin  Admin  @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([adminId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actorName String
  actorRole String
  action    String // CREATE | UPDATE | DELETE
  entity    String // report | expense | branch | admin | room | source
  entityId  String?
  summary   String
  changes   String? // JSON: [{ field, label, from, to }]
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entity])
}
