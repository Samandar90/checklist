generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  admins   Admin[]
  rooms    Room[]
  reports  MonthlyReport[]
  expenses Expense[]
}

model Admin {
  id        String   @id @default(cuid())
  fullName  String
  phone     String
  branchId  String
  createdAt DateTime @default(now())

  branch   Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  reports  MonthlyReport[]
  expenses Expense[]
  user     User?
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("ADMIN")
  adminId      String?  @unique
  createdAt    DateTime @default(now())

  admin Admin? @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model Room {
  id         String   @id @default(cuid())
  roomNumber String
  type       String? // тип номера: DBL, TWIN, Lux …
  branchId   String
  createdAt  DateTime @default(now())

  branch  Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  reports MonthlyReport[]
}

model BookingSource {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  reports MonthlyReport[]
}

model MonthlyReport {
  id        String    @id @default(cuid())
  date      DateTime // дата заезда (check-in)
  checkOut  DateTime? // дата выезда (check-out); null = одна ночь
  guestName String? // имя гостя
  branchId  String
  adminId   String
  roomId    String
  sourceId  String
  price         Float
  currency      String
  paymentMethod String   @default("Наличные")
  paymentStatus String   @default("Оплачено")
  paidAmount    Float?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime? @updatedAt

  branch Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  admin  Admin         @relation(fields: [adminId], references: [id], onDelete: Cascade)
  room   Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  source BookingSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model Expense {
  id        String    @id @default(cuid())
  date      DateTime
  branchId  String
  adminId   String?
  category  String
  amount    Float
  currency  String    @default("UZS")
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  admin  Admin? @relation(fields: [adminId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actorName String
  actorRole String
  action    String // CREATE | UPDATE | DELETE
  entity    String // report | expense | branch | admin | room | source
  entityId  String?
  summary   String
  changes   String? // JSON: [{ field, label, from, to }]
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entity])
}
