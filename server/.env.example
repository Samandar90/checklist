DATABASE_URL="file:./dev.db"
PORT=4000

# Hotel timezone. The server does date maths in local time (today's revenue,
# month/year ranges), so this must match the hotel — otherwise "today" follows
# the host clock (UTC on most hosts) and is a day off during the night shift.
TZ="Asia/Tashkent"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
SUPER_ADMIN_USERNAME="admin"
SUPER_ADMIN_PASSWORD="admin123"

# Optional: comma-separated list of allowed CORS origins (e.g. https://app.example.com).
# Leave empty to allow all origins (fine when the SPA is served from the same origin).
ALLOWED_ORIGINS=""
